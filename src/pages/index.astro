---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

const tagColors: Record<string, string> = {
	coding: '#f48120',
	security: '#e04e39',
	performance: '#2337ff',
	'open-source': '#1da562',
	nodejs: '#68a063',
	personal: '#8b5cf6',
};

function getTagColor(tag: string | undefined): string {
	if (!tag) return '#f48120';
	return tagColors[tag.toLowerCase()] || '#f48120';
}

function getTag(post: any): string {
	return post.data?.tag || 'coding';
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${SITE_TITLE} — Blog`}
			description={SITE_DESCRIPTION}
		/>
	</head>
	<body>
		<Header />
		<div class="cf-blog-page">
			<!-- Featured Post -->
			{featured && (
				<section class="cf-featured">
					<div class="cf-featured-content">
						{featured.data.heroImage && (
							<img src={featured.data.heroImage} alt="" class="cf-featured-img" />
						)}
						<div class="cf-featured-text">
							<h1 class="cf-featured-title">
								<a href={`/blog/${featured.id}/`}>{featured.data.title}</a>
							</h1>
							<p class="cf-featured-date"><FormattedDate date={featured.data.pubDate} /></p>
							<div class="cf-featured-tags">
								<span class="cf-tag" style={`background: ${getTagColor(getTag(featured))}`}>{getTag(featured)}</span>
							</div>
							<p class="cf-featured-desc">{featured.data.description}</p>
							<a href={`/blog/${featured.id}/`} class="cf-continue-reading">Continue reading &raquo;</a>
						</div>
					</div>
				</section>
			)}

			<hr class="cf-divider" />

			<!-- Posts Grid -->
			{rest.length > 0 && (
				<div class="cf-grid">
					{rest.map((post) => (
						<article class="cf-card">
							<h2 class="cf-card-title">
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</h2>
							<p class="cf-card-date"><FormattedDate date={post.data.pubDate} /></p>
							<div class="cf-card-tags">
								<span class="cf-tag" style={`background: ${getTagColor(getTag(post))}`}>{getTag(post)}</span>
							</div>
							<p class="cf-card-desc">{post.data.description}</p>
						</article>
					))}
				</div>
			)}
		</div>
		<Footer />
	</body>
</html>

<style is:global>
	.cf-blog-page {
		width: 1200px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2em 1em 3em;
	}

	/* Featured */
	.cf-featured {
		padding: 1em 0 2em;
	}

	.cf-featured-content {
		display: flex;
		gap: 2em;
		align-items: flex-start;
	}

	.cf-featured-img {
		width: 180px;
		height: 130px;
		object-fit: cover;
		border-radius: 8px;
		flex-shrink: 0;
	}

	.cf-featured-text {
		flex: 1;
	}

	.cf-featured-title {
		font-size: 1.6em;
		line-height: 1.3;
		margin: 0 0 0.3em;
		font-weight: 700;
		color: rgb(var(--black));
	}

	.cf-featured-title a {
		color: inherit;
		text-decoration: none;
	}

	.cf-featured-title a:hover {
		color: var(--accent);
	}

	.cf-featured-date {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0 0 0.5em;
	}

	.cf-featured-tags {
		margin-bottom: 0.8em;
	}

	.cf-tag {
		display: inline-block;
		padding: 0.15em 0.6em;
		font-size: 0.7em;
		font-weight: 600;
		color: white;
		background: #36393a !important;
		border-radius: 4px;
		text-transform: capitalize;
		margin-right: 0.3em;
	}

	.cf-featured-desc {
		font-size: 0.92em;
		color: rgb(var(--gray-dark));
		line-height: 1.6;
		margin: 0 0 0.8em;
	}

	.cf-continue-reading {
		font-size: 0.88em;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
	}

	.cf-continue-reading:hover {
		text-decoration: underline;
	}

	.cf-divider {
		border: none;
		border-top: 1px solid rgb(var(--gray-light));
		margin: 0 0 2em;
	}

	/* Grid */
	.cf-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5em 3em;
	}

	.cf-card {
		padding-bottom: 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	.cf-card-title {
		font-size: 1.15em;
		line-height: 1.35;
		margin: 0 0 0.3em;
		font-weight: 700;
		color: rgb(var(--black));
	}

	.cf-card-title a {
		color: inherit;
		text-decoration: none;
	}

	.cf-card-title a:hover {
		color: var(--accent);
	}

	.cf-card-date {
		font-size: 0.78em;
		color: rgb(var(--gray));
		margin: 0 0 0.5em;
	}

	.cf-card-tags {
		margin-bottom: 0.6em;
	}

	.cf-card-desc {
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
		line-height: 1.6;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.cf-featured-content {
			flex-direction: column;
		}
		.cf-featured-img {
			width: 100%;
			height: 140px;
		}
		.cf-featured-title {
			font-size: 1.3em;
		}
		.cf-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
