---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const props = Astro.props as any;
const { title, description, pubDate, updatedDate, heroImage, tag, authors } = props;

const allPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = allPosts.findIndex((p) => p.data.title === title);
const relatedPosts = allPosts.filter((_, i) => i !== currentIndex).slice(0, 3);

const tagColors: Record<string, string> = {
	coding: '#f48120',
	security: '#e04e39',
	performance: '#2337ff',
	'open-source': '#1da562',
	nodejs: '#68a063',
};

function getTagColor(t: string): string {
	return tagColors[t?.toLowerCase()] || '#f48120';
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<div class="cf-post-page">
			<article>
				<div class="cf-post-content">
					<div class="cf-post-header">
						<h1 class="cf-post-title">{title}</h1>
						<div class="cf-post-meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="cf-post-updated">
									&middot; Updated: <FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						{tag && (
							<div class="cf-post-tags">
								<span class="cf-post-tag" style={`background: ${getTagColor(tag)}`}>{tag}</span>
							</div>
						)}
						{heroImage && (
							<div class="cf-post-hero">
								<img src={heroImage} alt="" class="cf-post-hero-img" />
							</div>
						)}
					</div>
					<div class="cf-post-body prose">
						<slot />
					</div>
				</div>
			</article>

			<!-- Related Posts -->
			{relatedPosts.length > 0 && (
				<section class="cf-related">
					<h3 class="cf-related-heading">Related Posts</h3>
					<div class="cf-related-grid">
						{relatedPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="cf-related-card">
								<h4 class="cf-related-title">{post.data.title}</h4>
								<p class="cf-related-desc">{post.data.description}</p>
								<span class="cf-related-meta">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						))}
					</div>
				</section>
			)}
		</div>
		<Footer />
	</body>
</html>

<style is:global>
	.cf-post-page {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	/* Content */
	.cf-post-content {
		width: 760px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2em 1em 3em;
	}

	/* Header */
	.cf-post-header {
		margin-bottom: 2em;
	}

	.cf-post-title {
		font-size: 2.2em;
		letter-spacing: -0.02em;
		line-height: 1.2;
		margin: 0 0 0.4em;
		color: rgb(var(--black));
	}

	.cf-post-meta {
		font-size: 0.82em;
		color: rgb(var(--gray));
		margin-bottom: 0.6em;
	}

	.cf-post-updated {
		color: rgb(var(--gray));
	}

	.cf-post-tags {
		margin-bottom: 1.2em;
	}

	.cf-post-tag {
		display: inline-block;
		padding: 0.15em 0.6em;
		font-size: 0.7em;
		font-weight: 600;
		color: white;
		border-radius: 4px;
		text-transform: capitalize;
	}

	.cf-post-hero {
		margin: 1.5em 0 0;
	}

	.cf-post-hero-img {
		width: 100%;
		max-width: 960px;
		height: auto;
		border-radius: 8px;
		display: block;
	}

	/* Body content */
	.cf-post-body {
		color: rgb(var(--gray-dark));
		line-height: 1.8;
		font-size: 1em;
	}

	.cf-post-body h2 {
		font-size: 1.5em;
		margin: 2em 0 0.6em;
		letter-spacing: -0.01em;
		padding-bottom: 0.3em;
		border-bottom: 1px solid rgb(var(--gray-light));
		color: rgb(var(--black));
	}

	.cf-post-body h3 {
		font-size: 1.25em;
		margin: 1.5em 0 0.5em;
		color: rgb(var(--black));
	}

	.cf-post-body p {
		margin-bottom: 1.5em;
	}

	.cf-post-body a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}

	.cf-post-body a:hover {
		text-decoration-thickness: 2px;
	}

	.cf-post-body ul, .cf-post-body ol {
		margin-bottom: 1.5em;
		padding-left: 1.5em;
	}

	.cf-post-body li {
		margin-bottom: 0.4em;
	}

	.cf-post-body code {
		padding: 0.15em 0.4em;
		font-size: 0.88em;
		background: rgb(var(--gray-light));
		border-radius: 4px;
		font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
	}

	.cf-post-body pre {
		padding: 1.5em;
		border-radius: 8px;
		background: #1e1e2e;
		overflow-x: auto;
		margin-bottom: 1.5em;
	}

	.cf-post-body pre code {
		all: unset;
		font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
		font-size: 0.85em;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.85);
	}

	.cf-post-body blockquote {
		border-left: 3px solid var(--accent);
		padding: 0.8em 0 0.8em 1.5em;
		margin: 1.5em 0;
		background: rgba(35, 55, 255, 0.03);
		border-radius: 0 8px 8px 0;
		font-size: 1em;
	}

	.cf-post-body img {
		border-radius: 8px;
		margin: 1em 0;
	}

	.cf-post-body hr {
		border: none;
		height: 1px;
		background: rgb(var(--gray-light));
		margin: 2em 0;
	}

	/* Related Posts */
	.cf-related {
		width: 760px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 0 1em 3em;
		border-top: 1px solid rgb(var(--gray-light));
	}

	.cf-related-heading {
		font-size: 1.1em;
		font-weight: 700;
		color: rgb(var(--black));
		margin: 2em 0 1em;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.cf-related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}

	.cf-related-card {
		text-decoration: none;
		color: inherit;
		padding: 1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		transition: border-color 0.2s;
	}

	.cf-related-card:hover {
		border-color: var(--accent);
	}

	.cf-related-title {
		font-size: 0.9em;
		line-height: 1.3;
		margin: 0 0 0.5em;
		font-weight: 700;
		color: rgb(var(--black));
	}

	.cf-related-card:hover .cf-related-title {
		color: var(--accent);
	}

	.cf-related-desc {
		font-size: 0.78em;
		color: rgb(var(--gray));
		line-height: 1.5;
		margin: 0 0 0.5em;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.cf-related-meta {
		font-size: 0.72em;
		color: rgb(var(--gray));
	}

	/* Responsive */
	@media (max-width: 768px) {
		.cf-post-title { font-size: 1.7em; }
		.cf-post-content { padding: 1.5em 1em 2em; }
		.cf-related-grid { grid-template-columns: 1fr; }
	}
</style>
