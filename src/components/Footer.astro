---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-grid">
			<div class="footer-col">
				<h4>Getting Started</h4>
				<ul>
					<li><a href="/blog">Blog</a></li>
					<li><a href="/about">About</a></li>
					<li><a href="/consulting">Consulting</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>Resources</h4>
				<ul>
					<li><a href="/blog">Articles</a></li>
					<li><a href="/rss.xml">RSS Feed</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>Community</h4>
				<ul>
					<li><a href="https://github.com/mertcanaltin" target="_blank">GitHub</a></li>
					<li><a href="https://twitter.com/mecaltin" target="_blank">Twitter</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>Connect</h4>
				<ul>
					<li><a href="/contact">Contact</a></li>
					<li><a href="/newsletter">Newsletter</a></li>
				</ul>
			</div>
		</div>
		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} Mert Can Altin. All rights reserved.</p>
		</div>
	</div>
</footer>
<style>
	footer {
		background: #2c2f30;
		color: rgba(255, 255, 255, 0.7);
		padding: 3em 1.5em 2em;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2em;
		padding-bottom: 2em;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-col h4 {
		font-size: 0.75em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgba(255, 255, 255, 0.5);
		margin: 0 0 1em;
	}

	.footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.footer-col li {
		margin-bottom: 0.5em;
	}

	.footer-col a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		font-size: 0.8em;
	}

	.footer-col a:hover {
		color: white;
	}

	.footer-bottom {
		padding-top: 1.5em;
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.72em;
		color: rgba(255, 255, 255, 0.4);
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
